# Database
DATABASE_URL="postgresql://user:password@localhost:5432/geoleoteka"

# JWT Auth
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="7d"

# SMSC.ru
SMSC_LOGIN="your_smsc_login"
SMSC_PASSWORD="your_smsc_password"

# Yandex Cloud
YANDEX_ACCESS_KEY="your_access_key"
YANDEX_SECRET_KEY="your_secret_key"
YANDEX_BUCKET="geoleoteka-uploads"
YANDEX_ENDPOINT="https://storage.yandexcloud.net"

# Yandex Maps
NEXT_PUBLIC_YANDEX_MAPS_API_KEY="your_yandex_maps_api_key"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (Resend) — transactional sender for booking/estimate/order confirmations.
# Sign up at https://resend.com, generate an API key, verify the geleoteka.ru
# domain (SPF + DKIM TXT records). Without RESEND_API_KEY the helpers run in
# mock mode (logs to console, no HTTP call). See docs/setup-email.md.
RESEND_API_KEY=
# Sender once the domain is verified in Resend. Until then, leave at the fallback below.
# RESEND_FROM="Geleoteka <info@geleoteka.ru>"  # uncomment once domain is verified in Resend
RESEND_FROM_FALLBACK="onboarding@resend.dev"

# Webhook signing secret — Resend dashboard → Webhooks → "Reveal signing secret".
# Required to authenticate POST /api/email/inbound. In production, the route
# returns 503 (and Resend retries surface the misconfig) when this is unset.
RESEND_WEBHOOK_SECRET=
