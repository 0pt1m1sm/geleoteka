# ── Обязательные (bootstrap — только через env, в базе жить не могут) ──────
# Локальная разработка: postgresql://<юзер>@localhost:5432/geleoteka
# Прод: задаётся в переменных приложения Timeweb, НЕ здесь.
DATABASE_URL="postgresql://user:password@localhost:5432/geleoteka"

# Подпись JWT-сессий. Для dev — любая строка 32+ символов (у каждой машины своя).
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="7d"

# Абсолютный URL сайта (вшивается в клиентский бандл при сборке).
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ── Опциональные env-фолбэки ────────────────────────────────────────────────
# Интеграционные ключи (Resend, SMSC и будущие) задаются в АДМИНКЕ:
# /admin/settings/integrations → таблица Setting. Порядок разрешения:
# строка в БД → переменная окружения → null (см. lib/settings.ts).
# Env-переменные ниже нужны только как fallback, когда в БД значения нет.

# Email (Resend): без ключа письма работают в mock-режиме (лог в консоль).
# RESEND_API_KEY=
# RESEND_FROM="Geleoteka <info@geleoteka.ru>"   # после верификации домена в Resend
# RESEND_FROM_FALLBACK="onboarding@resend.dev"
# RESEND_WEBHOOK_SECRET=                         # подпись входящих /api/email/inbound

# S+ (интеграция каталога) — выключена, пока не заданы обе переменные.
# SPLUS_API_URL=
# SPLUS_API_KEY=
