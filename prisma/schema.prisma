generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserRole {
  CLIENT
  MANAGER
  ADMIN
}

enum AppointmentStatus {
  BOOKED
  ACCEPTED
  DIAGNOSIS
  IN_REPAIR
  QC
  READY
  COMPLETED
  CANCELLED
}

enum EstimateStatus {
  PENDING
  APPROVED
  REJECTED
}

enum EstimateItemType {
  WORK
  PART
}

enum LoyaltyTransactionType {
  EARN
  REDEEM
  REFERRAL_BONUS
}

enum NotificationType {
  BOOKING_CONFIRMATION
  STATUS_CHANGE
  REMINDER_1_DAY
  REMINDER_SAME_DAY
  ESTIMATE_READY
}

enum LoyaltyTier {
  SILVER
  GOLD
  AMG_CLUB
}

// ============================================
// USER & AUTH
// ============================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  phone        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(CLIENT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  cars              Car[]
  appointments      Appointment[]
  loyaltyAccount    LoyaltyAccount?
  notifications     Notification[]
  referredBy        User?  @relation("Referral", fields: [referredById], references: [id])
  referredUsers     User[] @relation("Referral")
  referredById      String?
  passwordResets    PasswordReset[]
  blogPosts        BlogPost[]
  partOrders       PartOrder[]
  rentalBookings   RentalBooking[]

  @@index([email])
  @@index([phone])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  code      String   @db.VarChar(6)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
}

// ============================================
// VEHICLES
// ============================================

model Car {
  id        String   @id @default(cuid())
  userId    String
  vin       String?  @unique
  model     String   // e.g., "GLE 2023"
  year      Int
  mileage   Int      @default(0)
  color     String?
  plate     String?  // Госномер
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([userId])
}

// ============================================
// SERVICES & MASTER
// ============================================

model Service {
  id                String   @id @default(cuid())
  slug              String   @unique
  name              String
  description       String?
  priceMin          Int?     // Min price in rubles
  priceMax          Int?     // Max price in rubles
  durationMinutes   Int?     // Estimated duration
  applicableModels  String[] // e.g., ["GLE", "GLS", "G-Class"]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  appointments AppointmentService[]

  @@index([slug])
}

model Master {
  id             String   @id @default(cuid())
  name           String
  specialization String
  photo          String?  // URL to photo
  certifications String[] // e.g., ["STAR Diagnostics", "AMG Certified"]
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  appointments Appointment[]

  @@index([isActive])
}

// ============================================
// APPOINTMENTS
// ============================================

model Appointment {
  id          String            @id @default(cuid())
  userId     String
  carId      String
  masterId   String?
  status     AppointmentStatus @default(BOOKED)
  dateTime   DateTime
  notes      String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  completedAt DateTime?

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  car           Car                  @relation(fields: [carId], references: [id], onDelete: Cascade)
  master        Master?              @relation(fields: [masterId], references: [id], onDelete: SetNull)
  services      AppointmentService[]
  estimate      Estimate?
  loyaltyTransactions LoyaltyTransaction[]

  // Slot locking: unique date+master prevents double-booking
  @@unique([dateTime, masterId])
  @@index([userId])
  @@index([carId])
  @@index([status])
  @@index([dateTime])
}

model AppointmentService {
  appointmentId String
  serviceId     String

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  service     Service     @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@id([appointmentId, serviceId])
}

// ============================================
// ESTIMATES
// ============================================

model Estimate {
  id            String         @id @default(cuid())
  appointmentId String        @unique
  status        EstimateStatus @default(PENDING)
  total         Int            @default(0) // Total in rubles
  finalCost     Int?           // Actual cost after adjustments
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  sentAt        DateTime?      // When sent to client
  approvedAt    DateTime?
  rejectedAt    DateTime?

  appointment Appointment     @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  items       EstimateItem[]

  @@index([status])
}

model EstimateItem {
  id          String           @id @default(cuid())
  estimateId  String
  type        EstimateItemType
  description String
  quantity    Int              @default(1)
  unitPrice   Int              // Price per unit in rubles
  approved    Boolean?
  approvedAt  DateTime?
  rejectedAt  DateTime?

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
}

// ============================================
// LOYALTY
// ============================================

model LoyaltyAccount {
  id            String      @id @default(cuid())
  userId        String      @unique
  points        Int         @default(0)
  tier          LoyaltyTier @default(SILVER)
  referralCode  String      @unique @default(cuid())
  tierUpdatedAt DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions LoyaltyTransaction[]

  @@index([referralCode])
  @@index([tier])
}

model LoyaltyTransaction {
  id            String                 @id @default(cuid())
  accountId     String
  amount        Int                    // Positive = earned, negative = redeemed
  type          LoyaltyTransactionType
  appointmentId String?
  description   String?
  createdAt     DateTime              @default(now())

  account     LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  appointment Appointment?   @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([accountId])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  message   String
  sentAt    DateTime         @default(now())
  readAt    DateTime?
  metadata  Json?            // Additional data (appointmentId, etc.)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sentAt])
}

// ============================================
// CMS
// ============================================

model CMSBlock {
  id        String   @id @default(cuid())
  key       String   @unique // e.g., "home.hero.title"
  content   Json     // Rich text content
  updatedAt DateTime @updatedAt

  @@index([key])
}

model MasterProfile {
  id             String   @id @default(cuid())
  name           String
  role           String   // e.g., "Главный механик"
  bio            String?
  photo          String?
  experience     Int?     // Years
  certifications String[]
  sortOrder      Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([sortOrder])
  @@index([isActive])
}

// ============================================
// BLOG
// ============================================

model BlogPost {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  content     String   // Markdown content
  excerpt     String?  // Short description
  authorId    String?
  tags        String[] // e.g., ["oil", "brakes"]
  modelTags   String[] // e.g., ["GLE", "G-Class"]
  published    Boolean  @default(false)
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([published])
  @@index([authorId])
}

// ============================================
// PARTS SHOP
// ============================================

enum PartOrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  COMPLETED
  CANCELLED
}

model PartCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  parts Part[]

  @@index([slug])
}

model Part {
  id               String   @id @default(cuid())
  slug             String   @unique
  article          String   @unique // Артикул
  name             String
  description      String?
  price            Int      // Price in rubles
  compareAtPrice   Int?     // Old price for discount display
  quantity         Int      @default(0) // Stock
  isOEM            Boolean  @default(true)
  photos           String[] // URLs
  compatibleModels String[] // e.g., ["G-Class", "GLE"]
  categoryId       String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category   PartCategory?   @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems PartOrderItem[]

  @@index([slug])
  @@index([article])
  @@index([categoryId])
  @@index([isActive])
}

model PartOrder {
  id           String          @id @default(cuid())
  userId       String?
  status       PartOrderStatus @default(PENDING)
  total        Int             @default(0)
  contactName  String
  contactPhone String
  contactEmail String
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user  User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  items PartOrderItem[]

  @@index([userId])
  @@index([status])
}

model PartOrderItem {
  id        String @id @default(cuid())
  orderId   String
  partId    String
  quantity  Int    @default(1)
  unitPrice Int    // Price at time of order

  order PartOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  part  Part      @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([partId])
}

// ============================================
// RENTAL CARS
// ============================================

enum RentalBookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  RETURNED
  CANCELLED
}

model RentalCar {
  id           String   @id @default(cuid())
  model        String   // e.g., "G 500"
  year         Int
  dailyRate    Int      // Price per day in rubles
  photos       String[]
  description  String?
  isAvailable  Boolean  @default(true)
  plate        String?
  color        String?
  mileage      Int      @default(0)
  engine       String?  // e.g., "4.0 V8 Biturbo"
  horsepower   Int?     // e.g., 422
  transmission String?  // e.g., "9G-TRONIC"
  features     String[] // e.g., ["Кожаный салон", "Панорамная крыша"]
  seats        Int      @default(5)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bookings RentalBooking[]

  @@index([isAvailable])
}

model RentalBooking {
  id           String              @id @default(cuid())
  carId        String
  userId       String?
  status       RentalBookingStatus @default(PENDING)
  startDate    DateTime
  endDate      DateTime
  totalCost    Int
  contactName  String
  contactPhone String
  contactEmail String
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  car  RentalCar @relation(fields: [carId], references: [id], onDelete: Cascade)
  user User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([carId])
  @@index([userId])
  @@index([status])
}

// ============================================
// VACANCIES
// ============================================

model Vacancy {
  id          String   @id @default(cuid())
  title       String
  type        String   @default("Полная занятость")
  description String
  requirements String[]
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
}
