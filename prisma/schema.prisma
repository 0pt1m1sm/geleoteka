generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserPermissionRole {
  NONE // Cannot log in (suppliers and other non-login entities)
  CLIENT // Customer portal only
  MANAGER // Admin panel, day-to-day operations
  ADMIN // Full admin access including settings
}

enum VehicleOwnershipType {
  CUSTOMER // Owned by a customer, brought in for service
  RENTAL // Fleet vehicle available for rent
  LOANER // Courtesy car given during service
}

enum RepairOrderStatus {
  ESTIMATE // Initial quote, awaiting customer approval
  APPROVED // Customer approved, ready to start
  IN_PROGRESS // Work underway
  AWAITING_PARTS // Blocked on parts delivery
  QC // Quality check
  READY // Done, ready for pickup
  INVOICED // Invoice issued
  PAID // Payment received
  CLOSED // Fully completed
  CANCELLED // Cancelled by customer or shop
}

enum JobLineStatus {
  PROPOSED // Part of the estimate, awaiting approval
  APPROVED // Customer approved this job
  DECLINED // Customer declined this job (kept for history)
  DEFERRED // Postponed to next visit (upsell list)
  IN_PROGRESS // Work underway on this specific job
  DONE // Job completed
}

enum PartLineStatus {
  NEEDED // Part required but not yet ordered
  ORDERED // Purchase order placed with supplier
  RECEIVED // Part arrived at shop
  INSTALLED // Part installed on the vehicle
}

enum SupplierOrderStatus {
  DRAFT
  ORDERED
  IN_TRANSIT
  CUSTOMS
  RECEIVED
  COMPLETED
  CANCELLED
}

enum SupplierOrderItemType {
  PART
  CUSTOM
  FEE
  SERVICE
}

enum LoyaltyTransactionType {
  EARN
  REDEEM
  REFERRAL_BONUS
}

enum NotificationType {
  BOOKING_CONFIRMATION
  STATUS_CHANGE
  REMINDER_1_DAY
  REMINDER_SAME_DAY
  ESTIMATE_READY
}

enum LoyaltyTier {
  SILVER
  GOLD
  AMG_CLUB
}

enum PartOrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  COMPLETED
  CANCELLED
}

enum RentalBookingStatus {
  PENDING
  CONFIRMED
  ACTIVE
  RETURNED
  CANCELLED
}

// ============================================
// USER & AUTH (unified person model)
// ============================================

model User {
  id             String             @id @default(cuid())
  email          String             @unique
  phone          String             @unique
  passwordHash   String? // NULL for non-login entities (permissionRole=NONE)
  name           String
  permissionRole UserPermissionRole @default(CLIENT)

  // Identity flags — a single user can play multiple roles
  isCustomer Boolean @default(true)
  isMaster   Boolean @default(false)
  isSupplier Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Optional 1:1 profile extensions (only present when corresponding flag = true)
  customerProfile CustomerProfile?
  masterProfile   MasterProfile?
  supplierProfile SupplierProfile?

  // Relations — as customer
  vehicles       Vehicle[]       @relation("VehicleOwner")
  repairOrders   RepairOrder[]   @relation("RepairOrderCustomer")
  loyaltyAccount LoyaltyAccount?
  notifications  Notification[]
  passwordResets PasswordReset[]
  blogPosts      BlogPost[]
  partOrders     PartOrder[]
  rentalBookings RentalBooking[]

  // Relations — as master/technician
  assignedRepairOrders RepairOrder[] @relation("RepairOrderMaster")
  assignedLaborLines   LaborLine[]   @relation("LaborLineTechnician")

  // Relations — as supplier
  supplierOrders SupplierOrder[]

  // Self-referential — referrals
  referredBy    User?   @relation("Referral", fields: [referredById], references: [id])
  referredUsers User[]  @relation("Referral")
  referredById  String?

  @@index([email])
  @@index([phone])
  @@index([isCustomer])
  @@index([isMaster])
  @@index([isSupplier])
  @@index([permissionRole])
}

model CustomerProfile {
  userId                String  @id @unique
  preferredMasterUserId String?
  blacklisted           Boolean @default(false)
  notes                 String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model MasterProfile {
  userId          String   @id @unique
  specialty       String?
  yearsExperience Int?
  bio             String?
  photoUrl        String?
  certifications  String[]
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([sortOrder])
}

model SupplierProfile {
  userId      String  @id @unique
  contactName String?
  country     String?
  notes       String?
  isActive    Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isActive])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  code      String    @db.VarChar(6)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
}

// ============================================
// VEHICLES (unified: customer cars + rental fleet)
// ============================================

model Vehicle {
  id            String               @id @default(cuid())
  ownershipType VehicleOwnershipType @default(CUSTOMER)
  ownerUserId   String? // Required for CUSTOMER, null for RENTAL/LOANER

  // Shared identification
  vin   String? @unique
  plate String?
  make  String  @default("Mercedes-Benz")
  model String // e.g., "G 500", "GLE 350d"
  year  Int
  color String?

  // Specs (useful for both customer cars and fleet)
  engine       String?
  horsepower   Int?
  transmission String?
  features     String[]
  seats        Int      @default(5)
  mileage      Int      @default(0)

  // Fleet-specific (null for customer cars)
  dailyRate   Int?
  isAvailable Boolean  @default(true)
  description String?
  photos      String[]

  // Soft-delete: hard-delete cascades to RentalBooking + RepairOrder, wiping history
  isArchived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  owner          User?           @relation("VehicleOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  repairOrders   RepairOrder[]
  rentalBookings RentalBooking[]

  @@index([ownerUserId])
  @@index([ownershipType])
  @@index([isAvailable])
  @@index([isArchived])
}

// ============================================
// SERVICES (catalog — what the shop offers)
// ============================================

model Service {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  description      String?
  priceMin         Int?
  priceMax         Int?
  durationMinutes  Int?
  applicableModels String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([slug])
}

// ============================================
// REPAIR ORDERS (unified: replaces Appointment + Estimate)
// ============================================

model RepairOrder {
  id           String            @id @default(cuid())
  roNumber     String?           @unique // Human-friendly sequential number
  userId       String // Customer
  vehicleId    String
  masterUserId String? // Assigned technician
  status       RepairOrderStatus @default(ESTIMATE)
  dateTime     DateTime // Scheduled date/time
  mileageIn    Int?
  mileageOut   Int?
  concern      String? // Customer's words: "what's wrong"
  notes        String?

  // Financial summary (computed from job lines)
  subtotalLabor Int @default(0)
  subtotalParts Int @default(0)
  tax           Int @default(0)
  discount      Int @default(0)
  total         Int @default(0)

  promisedAt  DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Relations
  user    User    @relation("RepairOrderCustomer", fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  master  User?   @relation("RepairOrderMaster", fields: [masterUserId], references: [id], onDelete: SetNull)
  slot    Slot?

  jobLines            JobLine[]
  loyaltyTransactions LoyaltyTransaction[]

  @@index([userId])
  @@index([vehicleId])
  @@index([masterUserId])
  @@index([status])
  @@index([dateTime])
}

// Slot locking: one row per scheduled time. Non-nullable unique dateTime
// makes concurrent booking attempts at the same time fail at the DB level.
// NOTE: single-bay shop assumption — one booking per dateTime across the
// whole workshop. Multi-bay capacity is out of scope for the redesign;
// upgrade later by replacing @unique([dateTime]) with @unique([dateTime, bayId])
// or introducing a capacity counter.
model Slot {
  id            String   @id @default(cuid())
  dateTime      DateTime @unique
  repairOrderId String   @unique
  createdAt     DateTime @default(now())

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
}

model JobLine {
  id            String        @id @default(cuid())
  repairOrderId String
  sortOrder     Int           @default(0)
  description   String // "Brake pad replacement", "Oil change", etc.
  status        JobLineStatus @default(PROPOSED)

  // Financial totals (computed from labor + part lines)
  laborTotal Int @default(0)
  partsTotal Int @default(0)
  total      Int @default(0)

  createdAt DateTime @default(now())

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  laborLines  LaborLine[]
  partLines   PartLine[]

  @@index([repairOrderId])
  @@index([status])
}

model LaborLine {
  id               String  @id @default(cuid())
  jobLineId        String
  description      String
  bookHours        Float   @default(0) // Estimated hours (from flat-rate guide)
  actualHours      Float? // Actual hours worked
  rate             Int     @default(0) // Rate per hour in rubles
  total            Int     @default(0)
  technicianUserId String? // Which technician performed this

  createdAt DateTime @default(now())

  jobLine    JobLine @relation(fields: [jobLineId], references: [id], onDelete: Cascade)
  technician User?   @relation("LaborLineTechnician", fields: [technicianUserId], references: [id], onDelete: SetNull)

  @@index([jobLineId])
}

model PartLine {
  id             String         @id @default(cuid())
  jobLineId      String
  partId         String? // Nullable — free-text for special-order / non-catalog parts
  description    String
  qty            Int            @default(1)
  unitCost       Int            @default(0) // What we pay
  unitPrice      Int            @default(0) // What we charge
  supplierUserId String? // Which supplier for this part
  status         PartLineStatus @default(NEEDED)

  createdAt DateTime @default(now())

  jobLine JobLine @relation(fields: [jobLineId], references: [id], onDelete: Cascade)
  part    Part?   @relation(fields: [partId], references: [id], onDelete: SetNull)

  @@index([jobLineId])
  @@index([partId])
}

// ============================================
// LOYALTY
// ============================================

model LoyaltyAccount {
  id            String      @id @default(cuid())
  userId        String      @unique
  points        Int         @default(0)
  tier          LoyaltyTier @default(SILVER)
  referralCode  String      @unique @default(cuid())
  tierUpdatedAt DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions LoyaltyTransaction[]

  @@index([referralCode])
  @@index([tier])
}

model LoyaltyTransaction {
  id            String                 @id @default(cuid())
  accountId     String
  amount        Int
  type          LoyaltyTransactionType
  repairOrderId String? // Was appointmentId — now links to RepairOrder
  description   String?
  createdAt     DateTime               @default(now())

  account     LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  repairOrder RepairOrder?   @relation(fields: [repairOrderId], references: [id], onDelete: SetNull)

  @@index([accountId])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id       String           @id @default(cuid())
  userId   String
  type     NotificationType
  message  String
  sentAt   DateTime         @default(now())
  readAt   DateTime?
  metadata Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sentAt])
}

// ============================================
// CMS & BLOG
// ============================================

model CMSBlock {
  id        String   @id @default(cuid())
  key       String   @unique
  content   Json
  updatedAt DateTime @updatedAt

  @@index([key])
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  content     String
  excerpt     String?
  authorId    String?
  tags        String[]
  modelTags   String[]
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([published])
  @@index([authorId])
}

// ============================================
// PARTS SHOP
// ============================================

model PartCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  parts Part[]

  @@index([slug])
}

model Part {
  id               String   @id @default(cuid())
  slug             String   @unique
  article          String   @unique
  name             String
  description      String?
  price            Int
  compareAtPrice   Int?
  quantity         Int      @default(0)
  isOEM            Boolean  @default(true)
  photos           String[]
  compatibleModels String[]
  categoryId       String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  category           PartCategory?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems         PartOrderItem[]
  supplierOrderItems SupplierOrderItem[]
  partLines          PartLine[]

  @@index([slug])
  @@index([article])
  @@index([categoryId])
  @@index([isActive])
}

model PartOrder {
  id           String          @id @default(cuid())
  userId       String?
  status       PartOrderStatus @default(PENDING)
  total        Int             @default(0)
  contactName  String
  contactPhone String
  contactEmail String
  notes        String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  user  User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  items PartOrderItem[]

  @@index([userId])
  @@index([status])
}

model PartOrderItem {
  id        String @id @default(cuid())
  orderId   String
  partId    String
  quantity  Int    @default(1)
  unitPrice Int

  order PartOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  part  Part      @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([partId])
}

// ============================================
// RENTAL BOOKINGS
// ============================================

model RentalBooking {
  id           String              @id @default(cuid())
  vehicleId    String // Was carId — now references Vehicle
  userId       String?
  status       RentalBookingStatus @default(PENDING)
  startDate    DateTime
  endDate      DateTime
  totalCost    Int
  contactName  String
  contactPhone String
  contactEmail String
  notes        String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([vehicleId])
  @@index([userId])
  @@index([status])
}

// ============================================
// VACANCIES
// ============================================

model Vacancy {
  id           String   @id @default(cuid())
  title        String
  type         String   @default("Полная занятость")
  description  String
  requirements String[]
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
}

// ============================================
// SUPPLIER ORDERS
// ============================================

model SupplierOrder {
  id               String              @id @default(cuid())
  userId           String // Was supplierId — references User (isSupplier=true)
  orderNumber      String?
  orderDate        DateTime
  status           SupplierOrderStatus @default(DRAFT)
  itemsCost        Int                 @default(0)
  shippingCost     Int                 @default(0)
  customsCost      Int                 @default(0)
  totalCost        Int                 @default(0)
  sellingPrice     Int                 @default(0)
  estimatedProfit  Int                 @default(0)
  trackingNumber   String?
  estimatedArrival DateTime?
  receivedAt       DateTime?
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  supplier User                @relation(fields: [userId], references: [id])
  items    SupplierOrderItem[]

  @@index([userId])
  @@index([status])
  @@index([orderDate])
}

model SupplierOrderItem {
  id          String                @id @default(cuid())
  orderId     String
  type        SupplierOrderItemType @default(PART)
  partId      String?
  description String
  quantity    Int                   @default(1)
  unitCost    Int
  totalCost   Int

  order SupplierOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  part  Part?         @relation(fields: [partId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([partId])
}

// ============================================
// VEHICLE CATALOG — Manufacturer / Model / Generation
// Source of truth for the picker. Service.applicableModels and
// Part.compatibleModels still use string arrays keyed by VehicleModel.name
// for a soft join — refactoring those to FKs is a follow-up.
// ============================================

model Manufacturer {
  id        String         @id @default(cuid())
  slug      String         @unique
  name      String
  sortOrder Int            @default(0)
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  models    VehicleModel[]

  @@index([isActive, sortOrder])
}

model VehicleModel {
  id             String              @id @default(cuid())
  slug           String              @unique
  name           String
  description    String?
  engines        String?
  features       String[]            @default([])
  manufacturerId String
  sortOrder      Int                 @default(0)
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  manufacturer   Manufacturer        @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)
  generations    VehicleGeneration[]

  @@index([manufacturerId, sortOrder])
  @@index([isActive])
}

model VehicleGeneration {
  id        String       @id @default(cuid())
  code      String
  yearFrom  Int
  yearTo    Int?
  modelId   String
  sortOrder Int          @default(0)
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  model     VehicleModel @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@unique([modelId, code])
  @@index([modelId, sortOrder])
  @@index([isActive])
}
