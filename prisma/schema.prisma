generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum UserPermissionRole {
  NONE // Cannot log in (suppliers and other non-login entities)
  CLIENT // Customer portal only (/cabinet)
  MASTER // Technician portal only (/master) — assigned RepairOrders queue
  MANAGER // Admin panel, day-to-day operations
  ADMIN // Full admin access including settings
  WAREHOUSE_WORKER // Warehouse operations only (scan, putaway, move, adjust) — no other admin sections
}

enum VehicleOwnershipType {
  CUSTOMER // Owned by a customer, brought in for service
  RENTAL // Fleet vehicle available for rent
  LOANER // Courtesy car given during service
}

enum RepairOrderStatus {
  // Estimate-stage approval lives on the Estimate now; RO tracks WORK only.
  SCHEDULED // Принят и ждёт работ (заменяет ESTIMATE + APPROVED)
  IN_PROGRESS // В работе (включая ожидание запчастей, контроль качества)
  READY // Готов к выдаче / счёт выставлен
  COMPLETED // Выдан и оплачен (заменяет PAID + CLOSED)
  CANCELLED // Отменён клиентом или цехом
}

enum JobLineStatus {
  PROPOSED // Part of the estimate, awaiting approval
  APPROVED // Customer approved this job
  DECLINED // Customer declined this job (kept for history)
  DEFERRED // Postponed to next visit (upsell list)
  IN_PROGRESS // Work underway on this specific job
  DONE // Job completed
}

enum PartLineStatus {
  NEEDED // Part required but not yet ordered
  ORDERED // Purchase order placed with supplier
  RECEIVED // Part arrived at shop
  INSTALLED // Part installed on the vehicle
}

enum SupplierOrderStatus {
  DRAFT
  ORDERED
  IN_TRANSIT
  CUSTOMS
  PARTIALLY_RECEIVED
  RECEIVED
  COMPLETED
  CANCELLED
}

enum SupplierOrderItemType {
  PART
  CUSTOM
  FEE
  SERVICE
}

enum CustomsMode {
  PERCENT_CIF // customs = % of CIF (itemsCost + shipping)
  CARGO_PER_KG // customs = weight × cargo $/kg × USD rate
}

enum LoyaltyTransactionType {
  EARN
  REDEEM
  REFERRAL_BONUS
}

enum NotificationType {
  BOOKING_CONFIRMATION
  STATUS_CHANGE
  REMINDER_1_DAY
  REMINDER_SAME_DAY
  ESTIMATE_READY
}

enum LoyaltyTier {
  SILVER
  GOLD
  AMG_CLUB
}

enum PartOrderStatus {
  PROCESSING // Принят, в обработке (заменяет PENDING + CONFIRMED)
  SHIPPED // Передан в доставку
  COMPLETED // Получен клиентом
  CANCELLED
}

enum RentalBookingStatus {
  BOOKED // Забронирован, до выдачи (заменяет PENDING + CONFIRMED)
  ACTIVE // Автомобиль у клиента
  RETURNED // Возвращён, расчёты закрыты
  CANCELLED
}

// ============================================
// CRM — Deal aggregate + Estimate
// ============================================
// Deal is the commercial root: every transaction (workshop service,
// parts purchase, rental) is a Deal. Operational fulfillments
// (RepairOrder, PartOrder, RentalBooking) link back via dealId. See
// docs/prd/2026-05-10-deal-fulfillment-architecture.md.

enum DealStage {
  NEW         // создана; нет ещё APPROVED-сметы. Заменяет DRAFT + QUOTED.
  IN_PROGRESS // есть APPROVED estimate; fulfillment либо ждёт, либо идёт, либо ждёт оплаты. Заменяет APPROVED + IN_FULFILLMENT + DELIVERED.
  WON         // фулфилмент завершён + оплачено. Manual transition.
  LOST        // отказ клиента / протух / отменён. Manual transition.
}

enum DealChannel {
  SERVICE
  PARTS_RETAIL
  PARTS_WHOLESALE
  RENTAL
  WALK_IN
}

enum DealPaymentStatus {
  UNPAID
  PARTIAL
  PAID
  REFUNDED
}

enum DealLineType {
  LABOR
  PART
  RENTAL_DAY
  DISCOUNT
  FEE
}

enum EstimateStage {
  DRAFT
  SENT
  APPROVED
  DECLINED
  EXPIRED
  SUPERSEDED
}

// Communications log (CRM Phase 3) — every customer touch the team can
// reference later. Channel covers phone, SMS, messengers, email,
// in-person. See docs/prd/2026-05-10-crm-expansion.md.
enum CommChannel {
  PHONE_INBOUND
  PHONE_OUTBOUND
  SMS_INBOUND
  SMS_OUTBOUND
  EMAIL_INBOUND
  EMAIL_OUTBOUND
  WHATSAPP_INBOUND
  WHATSAPP_OUTBOUND
  TELEGRAM_INBOUND
  TELEGRAM_OUTBOUND
  MAX_INBOUND
  MAX_OUTBOUND
  IN_PERSON
  OTHER
  // Legacy values kept on the enum to satisfy in-flight rows that may have
  // been written before the directional split — they are hidden from the
  // dropdown (see lib/crm-labels.ts) but readable for audit.
  WHATSAPP
  TELEGRAM
  EMAIL
}

enum InboxMessageStatus {
  PENDING
  ASSIGNED
  SPAM
  ARCHIVED
}

/// Audit log of every POST to /api/email/inbound — successful or not.
/// Lets the admin diagnose webhook chain problems (HMAC mismatch, wrong
/// recipient, missing secret) without Railway log access. Rows live ~30
/// days; cleanup is manual or via a future cron.
model InboundAttempt {
  id         String   @id @default(cuid())
  receivedAt DateTime @default(now())
  httpStatus Int
  outcome    String   // accepted_thread / accepted_customer / accepted_inbox / duplicate / rejected_signature / ignored_recipient / ignored_type / error_no_secret / error_no_api_key / error_upstream / error_other
  detail     String?
  recipient  String?
  fromEmail  String?
  messageId  String?
  hasSvixId  Boolean  @default(false)
  hasSig     Boolean  @default(false)
  hasTs      Boolean  @default(false)

  @@index([receivedAt])
  @@index([outcome])
}

/// Key-value store for runtime-mutable settings: integration secrets,
/// webhook credentials, feature flags an admin should be able to change
/// without redeploy. Read via lib/settings.ts:getSetting(key) which
/// falls back to process.env when the row is missing — so existing
/// env-var-driven config keeps working until an admin overrides it
/// through /admin/settings/integrations.
model Setting {
  id              String   @id @default(cuid())
  key             String   @unique
  value           String   @db.Text
  updatedAt       DateTime @updatedAt
  updatedByUserId String?

  updatedBy User? @relation("SettingUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([key])
}

enum CommOutcome {
  ANSWERED
  VOICEMAIL
  NO_ANSWER
  REPLIED
  DELIVERED
  FAILED
  N_A
}

// CRM tasks (CRM Phase 4) — manager reminders / follow-ups with
// due-date, owner, optional deal/customer link.
enum CrmTaskStatus {
  OPEN
  DONE
  CANCELLED
}

enum CrmTaskKind {
  CALLBACK
  FOLLOW_UP
  PAYMENT_REMINDER
  SCHEDULED_CHECK_IN
  GENERIC
}

enum FuelType {
  PETROL
  DIESEL
  ELECTRIC
  HYBRID
}

/// Marketing source — где клиент узнал о Geleoteka. Заполняется при
/// создании клиента или редактировании Customer 360. Отдельное от
/// User.referredBy (которое для user-to-user рефералов: один клиент
/// привёл другого).
enum ReferralSource {
  YANDEX
  GOOGLE
  AVITO
  INSTAGRAM
  TELEGRAM_CHAN
  FRIEND
  REPEAT
  WALK_IN
  EMAIL
  OTHER
}

// ============================================
// USER & AUTH (unified person model)
// ============================================

model User {
  id             String             @id @default(cuid())
  email          String             @unique
  phone          String             @unique
  passwordHash   String? // NULL for non-login entities (permissionRole=NONE)
  // True when passwordHash was generated by the booking/cart guest flow
  // (a bcrypt of a random string the user does not know). The post-checkout
  // auth panel uses this to decide between "Set password" and "Log in" tabs,
  // and setPasswordForGuestUser refuses to overwrite when this is false.
  isTempPassword Boolean            @default(false)
  name           String
  permissionRole UserPermissionRole @default(CLIENT)

  // Identity flags — a single user can play multiple roles
  isCustomer Boolean @default(true)
  isMaster   Boolean @default(false)
  isSupplier Boolean @default(false)

  // Marketing source — заполняется один раз при создании клиента.
  // Nullable because legacy customers + customers created before this
  // field existed will have unknown source.
  referralSource ReferralSource?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Soft-delete timestamp. NULL = active; non-NULL = hidden from CRM lists.
  // Hard delete (db.user.delete) is used only for guest accounts (isTempPassword=true);
  // every other delete sets this field so deal/RO history stays intact.
  deletedAt DateTime?

  // Optional 1:1 profile extensions (only present when corresponding flag = true)
  customerProfile CustomerProfile?
  masterProfile   MasterProfile?
  supplierProfile SupplierProfile?

  // Relations — as customer
  vehicles       Vehicle[]       @relation("VehicleOwner")
  repairOrders   RepairOrder[]   @relation("RepairOrderCustomer")
  loyaltyAccount LoyaltyAccount?
  notifications  Notification[]
  passwordResets PasswordReset[]
  blogPosts      BlogPost[]
  partShipments  PartShipment[]
  rentalBookings RentalBooking[]

  // CRM — manager timeline notes about this customer + tag assignments
  customerNotes        CustomerNote[]            @relation("CustomerNoteCustomer")
  authoredCustomerNotes CustomerNote[]           @relation("CustomerNoteAuthor")
  tagAssignments       CustomerTagAssignment[]

  // Secondary email/phone aliases — a customer who writes from a new
  // address gets it added here so future inbound auto-matches them.
  // The primary email/phone stay on this model; aliases are extras.
  contacts             CustomerContact[]

  // Relations — as master/technician
  assignedRepairOrders RepairOrder[] @relation("RepairOrderMaster")
  assignedLaborLines   LaborLine[]   @relation("LaborLineTechnician")

  // Relations — as supplier
  supplierOrders SupplierOrder[]

  // Relations — as uploader (admin who uploaded an image)
  uploadedImages UploadedImage[] @relation("UploadedImageCreator")

  // RepairOrder work photos uploaded by this user (master/admin/manager).
  uploadedRepairOrderPhotos RepairOrderPhoto[] @relation("RepairOrderPhotoUploader")

  // CRM — Deal/Estimate relations
  dealsAsCustomer    Deal[]     @relation("DealCustomer")
  dealsAsOwner       Deal[]     @relation("DealOwner")
  estimatesPrepared  Estimate[] @relation("EstimatePreparedBy")

  // CRM Phase 3 — Communications
  commLogsAsCustomer CommunicationLog[] @relation("CommLogCustomer")
  commLogsAuthored   CommunicationLog[] @relation("CommLogAuthor")

  // Inbound email inbox — messages assigned to this manager during triage
  assignedInboxMessages InboxMessage[] @relation("InboxAssignee")

  // Settings audit — admin who last updated a Setting row
  settingsUpdated Setting[] @relation("SettingUpdater")

  // CRM Phase 4 — Tasks
  crmTasksOwned    CrmTask[] @relation("CrmTaskOwner")
  crmTasksAsCustomer CrmTask[] @relation("CrmTaskCustomer")

  // Self-referential — referrals
  referredBy    User?   @relation("Referral", fields: [referredById], references: [id])
  referredUsers User[]  @relation("Referral")
  referredById  String?

  @@index([email])
  @@index([phone])
  @@index([isCustomer])
  @@index([isMaster])
  @@index([isSupplier])
  @@index([permissionRole])
  @@index([isCustomer, permissionRole])
  @@index([deletedAt])
}

model CustomerProfile {
  userId                String  @id @unique
  preferredMasterUserId String?
  blacklisted           Boolean @default(false)
  notes                 String?

  // CRM analytics (Phase 3). Maintained incrementally: lastTouchAt on each
  // communication, lifetimeValue on WON-deal transitions. Backfilled from
  // history at migration time.
  source        String? // earliest deal.source ("booking-form" | "parts-cart" | ...)
  firstSeenAt   DateTime?
  lastTouchAt   DateTime?
  lifetimeValue Int       @default(0) // Σ WON deal totals, kopecks

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum ContactType {
  EMAIL
  PHONE
}

// Secondary contact aliases for a customer. The primary email/phone live
// on User; these are additional addresses/numbers the same person uses.
// Inbound email resolution (lib/email/resolve.ts) matches the sender
// against User.email OR a CustomerContact EMAIL value, so a known customer
// writing from a new address is auto-attached once that address is added.
model CustomerContact {
  id        String      @id @default(cuid())
  userId    String
  type      ContactType
  value     String // normalized: lowercased email / normalizePhone'd number
  label     String? // optional human label ("рабочий", "личный")
  createdAt DateTime    @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // A given email/phone belongs to at most one customer alias — prevents
  // the same address pointing at two customers.
  @@unique([type, value])
  @@index([userId])
}

// CRM — manager-authored timeline notes attached to a customer User.
// Distinct from CustomerProfile.notes (a single free-form scratchpad).
// Body holds raw markdown source; rendered with react-markdown in the UI.
model CustomerNote {
  id             String   @id @default(cuid())
  customerUserId String
  authorUserId   String?
  body           String
  createdAt      DateTime @default(now())

  customer User  @relation("CustomerNoteCustomer", fields: [customerUserId], references: [id], onDelete: Cascade)
  author   User? @relation("CustomerNoteAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([customerUserId])
  @@index([authorUserId])
}

// CRM segment label. Color is a slug from the fixed 8-color palette
// (lib/customer-tags.ts → TAG_COLOR_PALETTE) — never a free-form hex.
model CustomerTag {
  id        String   @id @default(cuid())
  name      String   @unique
  colorSlug String
  createdAt DateTime @default(now())

  assignments CustomerTagAssignment[]

  @@index([name])
}

// Many-to-many between User (isCustomer=true) and CustomerTag.
// Composite primary key on (customerUserId, tagId) prevents duplicate assignments.
model CustomerTagAssignment {
  customerUserId String
  tagId          String
  createdAt      DateTime @default(now())

  customer User        @relation(fields: [customerUserId], references: [id], onDelete: Cascade)
  tag      CustomerTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([customerUserId, tagId])
  @@index([tagId])
}

model MasterProfile {
  userId          String   @id @unique
  specialty       String?
  yearsExperience Int?
  bio             String?
  photoUrl        String?
  certifications  String[]
  isActive        Boolean  @default(true)
  sortOrder       Int      @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isActive])
  @@index([sortOrder])
}

model SupplierProfile {
  userId      String  @id @unique
  contactName String?
  country     String?
  notes       String?
  isActive    Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([isActive])
}

model PasswordReset {
  id        String    @id @default(cuid())
  userId    String
  code      String    @db.VarChar(6)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
}

// ============================================
// VEHICLES (unified: customer cars + rental fleet)
// ============================================

model Vehicle {
  id            String               @id @default(cuid())
  ownershipType VehicleOwnershipType @default(CUSTOMER)
  ownerUserId   String? // Required for CUSTOMER, null for RENTAL/LOANER

  // Shared identification
  vin   String? @unique
  plate String?
  make  String  @default("Mercedes-Benz")
  model String // e.g., "G 500", "GLE 350d"
  year  Int
  color String?

  // Specs (useful for both customer cars and fleet)
  engine       String?
  horsepower   Int?
  transmission String?
  features     String[]
  seats        Int      @default(5)
  mileage      Int      @default(0)

  // Fleet-specific (null for customer cars)
  dailyRate   Int?
  isAvailable Boolean  @default(true)
  description String?
  photos      String[]

  // Soft-delete: hard-delete cascades to RentalBooking + RepairOrder, wiping history
  isArchived Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  owner          User?           @relation("VehicleOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  repairOrders   RepairOrder[]
  rentalBookings RentalBooking[]
  deals          Deal[]

  @@index([ownerUserId])
  @@index([ownershipType])
  @@index([isAvailable])
  @@index([isArchived])
}

// ============================================
// SERVICES (catalog — what the shop offers)
// ============================================

model Service {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  description      String?
  priceMin         Int?
  priceMax         Int?
  durationMinutes  Int?
  applicableModels String[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([slug])
}

// ============================================
// REPAIR ORDERS (unified: replaces Appointment + Estimate)
// ============================================

model RepairOrder {
  id           String            @id @default(cuid())
  roNumber     String?           @unique // Human-friendly sequential number
  userId       String // Customer
  vehicleId    String
  masterUserId String? // Assigned technician
  trimId       String? // Captured from booking picker; null for older flows or "Не уверен"
  status       RepairOrderStatus @default(SCHEDULED)
  dateTime     DateTime // Scheduled date/time
  mileageIn    Int?
  mileageOut   Int?
  concern      String? // Customer's words: "what's wrong"
  notes        String?

  // Financial summary (computed from job lines)
  subtotalLabor Int @default(0)
  subtotalParts Int @default(0)
  tax           Int @default(0)
  discount      Int @default(0)
  total         Int @default(0)

  // One-shot secret returned to a guest immediately after booking creation,
  // required by the post-checkout auth panel to claim/login the order.
  // Cleared (set to NULL) after the first successful claim or login.
  claimToken String?

  promisedAt  DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Phase 0 of Deal+Fulfillment migration. Locked NOT NULL after the
  // additive migration backfilled every existing RO with a Deal.
  // (PartOrder.dealId and RentalBooking.dealId stay nullable for now —
  // legacy guest orders without userId need a separate resolution
  // pass before they can be locked.)
  dealId String

  // Relations
  user    User         @relation("RepairOrderCustomer", fields: [userId], references: [id], onDelete: Cascade)
  vehicle Vehicle      @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  master  User?        @relation("RepairOrderMaster", fields: [masterUserId], references: [id], onDelete: SetNull)
  trim    VehicleTrim? @relation(fields: [trimId], references: [id], onDelete: SetNull)
  slot    Slot?
  deal    Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)

  jobLines            JobLine[]
  loyaltyTransactions LoyaltyTransaction[]
  workPhotos          RepairOrderPhoto[]

  @@index([userId])
  @@index([vehicleId])
  @@index([masterUserId])
  @@index([trimId])
  @@index([status])
  @@index([dateTime])
  @@index([claimToken])
  @@index([dealId])
}

/// Photo attached by a master/manager to a RepairOrder showing work
/// in progress or completed (e.g. "front brakes replaced", "oil 5W-40
/// filled"). Visible to the customer in their tracking view and to
/// admins in the order detail.
model RepairOrderPhoto {
  id            String   @id @default(cuid())
  repairOrderId String
  url           String
  caption       String?
  uploadedById  String?
  createdAt     DateTime @default(now())

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  uploadedBy  User?       @relation("RepairOrderPhotoUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([repairOrderId])
  @@index([uploadedById])
  @@index([createdAt])
}

// Slot locking: one row per scheduled time. Non-nullable unique dateTime
// makes concurrent booking attempts at the same time fail at the DB level.
// NOTE: single-bay shop assumption — one booking per dateTime across the
// whole workshop. Multi-bay capacity is out of scope for the redesign;
// upgrade later by replacing @unique([dateTime]) with @unique([dateTime, bayId])
// or introducing a capacity counter.
model Slot {
  id            String   @id @default(cuid())
  dateTime      DateTime @unique
  repairOrderId String   @unique
  createdAt     DateTime @default(now())

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
}

model JobLine {
  id            String        @id @default(cuid())
  repairOrderId String
  sortOrder     Int           @default(0)
  description   String // "Brake pad replacement", "Oil change", etc.
  status        JobLineStatus @default(PROPOSED)

  // Financial totals (computed from labor + part lines)
  laborTotal Int @default(0)
  partsTotal Int @default(0)
  total      Int @default(0)

  createdAt DateTime @default(now())

  repairOrder RepairOrder @relation(fields: [repairOrderId], references: [id], onDelete: Cascade)
  laborLines  LaborLine[]
  partLines   PartLine[]

  @@index([repairOrderId])
  @@index([status])
}

model LaborLine {
  id               String  @id @default(cuid())
  jobLineId        String
  description      String
  bookHours        Float   @default(0) // Estimated hours (from flat-rate guide)
  actualHours      Float? // Actual hours worked
  rate             Int     @default(0) // Rate per hour in rubles
  total            Int     @default(0)
  technicianUserId String? // Which technician performed this

  createdAt DateTime @default(now())

  jobLine    JobLine @relation(fields: [jobLineId], references: [id], onDelete: Cascade)
  technician User?   @relation("LaborLineTechnician", fields: [technicianUserId], references: [id], onDelete: SetNull)

  @@index([jobLineId])
}

model PartLine {
  id             String         @id @default(cuid())
  jobLineId      String
  partId         String? // Nullable — free-text for special-order / non-catalog parts
  description    String
  qty            Int            @default(1)
  unitCost       Int            @default(0) // What we pay
  unitPrice      Int            @default(0) // What we charge
  supplierUserId String? // Which supplier for this part
  status         PartLineStatus @default(NEEDED)

  createdAt DateTime @default(now())

  jobLine JobLine @relation(fields: [jobLineId], references: [id], onDelete: Cascade)
  part    Part?   @relation(fields: [partId], references: [id], onDelete: SetNull)

  @@index([jobLineId])
  @@index([partId])
}

// ============================================
// LOYALTY
// ============================================

model LoyaltyAccount {
  id            String      @id @default(cuid())
  userId        String      @unique
  points        Int         @default(0)
  tier          LoyaltyTier @default(SILVER)
  referralCode  String      @unique @default(cuid())
  tierUpdatedAt DateTime    @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions LoyaltyTransaction[]

  @@index([referralCode])
  @@index([tier])
}

model LoyaltyTransaction {
  id            String                 @id @default(cuid())
  accountId     String
  amount        Int
  type          LoyaltyTransactionType
  repairOrderId String? // Was appointmentId — now links to RepairOrder
  description   String?
  createdAt     DateTime               @default(now())

  account     LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  repairOrder RepairOrder?   @relation(fields: [repairOrderId], references: [id], onDelete: SetNull)

  @@index([accountId])
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id       String           @id @default(cuid())
  userId   String
  type     NotificationType
  message  String
  sentAt   DateTime         @default(now())
  readAt   DateTime?
  metadata Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sentAt])
}

// ============================================
// UPLOADED IMAGES (admin-uploaded photo bytes stored in Postgres BYTEA;
// served via GET /api/images/[id]; referenced by Part.photos / Vehicle.photos
// as `/api/images/<id>` URLs)
// ============================================

model UploadedImage {
  id          String   @id @default(cuid())
  bytes       Bytes
  mimeType    String
  width       Int
  height      Int
  size        Int
  createdAt   DateTime @default(now())
  createdById String?

  createdBy User? @relation("UploadedImageCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([createdById])
}

// ============================================
// CMS & BLOG
// ============================================

// `type` controls how `content` is shaped and how the public site renders it:
//   "text"     → content is { value: string }            — single-line strings
//   "richtext" → content is { markdown: string }         — markdown source
//   "list"     → content is { items: Array<Record<string,string>> } — repeating rows
// The set of keys, their `type`, and the per-list row shape are defined in
// `lib/cms-schema.ts`. The server action validates writes against that schema.
model CMSBlock {
  id        String   @id @default(cuid())
  key       String   @unique
  type      String   @default("text")
  content   Json
  updatedAt DateTime @updatedAt

  @@index([key])
}

model BlogPost {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  content     String
  excerpt     String?
  authorId    String?
  tags        String[]
  modelTags   String[]
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author User? @relation(fields: [authorId], references: [id], onDelete: SetNull)

  @@index([slug])
  @@index([published])
  @@index([authorId])
}

// ============================================
// PARTS SHOP
// ============================================

model PartCategory {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  parts Part[]

  @@index([slug])
}

model Part {
  id             String   @id @default(cuid())
  slug           String   @unique
  article        String   @unique
  name           String
  description    String?
  price          Int
  compareAtPrice Int?
  weightGrams    Int? // unit weight in grams; drives supplier-order shipping calc
  isOEM          Boolean  @default(true)
  photos         String[]
  categoryId     String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category           PartCategory?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  orderItems         PartOrderItem[]
  supplierOrderItems SupplierOrderItem[]
  partLines          PartLine[]
  partTrims          PartTrim[]
  estimateLines      EstimateLine[]
  stockItem          StockItem?

  @@index([slug])
  @@index([article])
  @@index([categoryId])
  @@index([isActive])
}

// ============================================
// WMS — Warehouse stock (extractable core; see docs/design/2026-05-22-wms-module-seam.md)
// StockItem owns physical stock (on-hand/reserved) keyed 1:1 to a Part.
// StockMovement is the append-only audit ledger. tenantKey is the single-tenant
// discriminator now (default "geleoteka"); all future tenant scoping funnels
// through these two tables + lib/wms/internal/repository.ts.
// ============================================

enum StockMovementReason {
  RECEIPT // inbound on-hand (supplier receipt)
  CONSUMPTION // outbound on-hand (RO close / shipment / retail sale)
  ADJUSTMENT // manual correction (the only reason allowed a null source)
  RESERVATION // raise reserved, leave on-hand
  RELEASE // lower reserved, leave on-hand
}

model StockItem {
  id        String   @id @default(cuid())
  partId    String   @unique
  quantity  Int      @default(0) // physical on-hand
  reserved  Int      @default(0) // held by open reservations; available = quantity - reserved
  barcode   String?
  gtin      String?
  tenantKey String   @default("geleoteka")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  part         Part                @relation(fields: [partId], references: [id], onDelete: Cascade)
  movements    StockMovement[]
  bins         StockBin[]
  binMovements StockBinMovement[]

  @@index([tenantKey, partId])
  @@index([barcode])
}

model StockMovement {
  id            String              @id @default(cuid())
  itemId        String
  reason        StockMovementReason
  quantityDelta Int                 @default(0) // signed on-hand delta
  reservedDelta Int                 @default(0) // signed reserved delta
  sourceType    String
  sourceId      String?
  actorUserId   String?
  note          String?
  // Client-supplied idempotency key (phone retry safety). Nullable: NULLs are
  // distinct in PG so only keyed writes dedupe. Independent of the source-triple
  // below — recordMovement disambiguates which unique fired on P2002.
  idempotencyKey String?
  tenantKey     String              @default("geleoteka")
  createdAt     DateTime            @default(now())

  item StockItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  // Idempotency: a given (tenant, source, reason) applies at most once.
  // sourceId is nullable (manual ADJUSTMENT); NULLs are distinct in PG so the
  // recordMovement guard forbids null sourceId for all reasons except ADJUSTMENT.
  @@unique([tenantKey, sourceType, sourceId, reason])
  @@unique([tenantKey, idempotencyKey])
  @@index([tenantKey, itemId, createdAt])
}

// Multi-bin placement layer over the aggregate StockItem (Phase 1 of the
// warehouse roadmap, docs/prd/2026-05-22-warehouse-wms-roadmap.md). StockBin
// records WHERE on-hand sits; Σ StockBin.quantity ≤ StockItem.quantity and
// unplaced = quantity − Σbins. Placement ops never change the aggregate.
// StockBinMovement is the append-only audit for bin-to-bin/unplaced moves
// (these have no aggregate delta, so they are NOT in StockMovement).
enum StockBinMovementReason {
  PLACE // unplaced → bin (putaway)
  TRANSFER // bin → bin
  REMOVE // bin → unplaced
  PICK // bin → consumed/outbound (bin-aware CONSUMPTION; aggregate already dropped)
}

model StockBin {
  id        String   @id @default(cuid())
  itemId    String
  location  String
  quantity  Int      @default(0)
  tenantKey String   @default("geleoteka")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  item StockItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([tenantKey, itemId, location])
  @@index([tenantKey, location])
}

model StockBinMovement {
  id           String                 @id @default(cuid())
  itemId       String
  reason       StockBinMovementReason
  fromLocation String?
  toLocation   String?
  quantity     Int
  actorUserId  String?
  note         String?
  // Client-supplied idempotency key (phone retry safety). Nullable; NULLs are
  // distinct in PG so only keyed placement writes dedupe.
  idempotencyKey String?
  tenantKey    String                 @default("geleoteka")
  createdAt    DateTime               @default(now())

  item StockItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([tenantKey, idempotencyKey])
  @@index([tenantKey, itemId, createdAt])
}

// Registry of physical warehouse locations (cells/bins addresses), WMS-owned and
// tenant-scoped. Distinct from StockBin (which is per-item placement keyed by
// location string): a StockLocation is the location itself, blocked/inactive for
// ALL items. `code` is normalized upper/trimmed by callers. LOCATION_BLOCKED
// (putaway/transfer-in rejection) checks isActive/isBlocked here.
model StockLocation {
  id        String   @id @default(cuid())
  code      String
  zone      String?
  isActive  Boolean  @default(true)
  isBlocked Boolean  @default(false)
  tenantKey String   @default("geleoteka")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantKey, code])
  @@index([tenantKey])
}

// Append-only audit of every scan, including failures. WMS-owned, tenant-scoped.
// userId is opaque (host user id; no FK to User, mirrors StockMovement.actorUserId).
enum ScanResult {
  SUCCESS
  REJECTED
  ERROR
}

model ScanEvent {
  id               String     @id @default(cuid())
  userId           String?
  deviceId         String?
  sessionId        String?
  action           String
  rawCode          String
  parsedObjectType String?
  parsedObjectId   String?
  result           ScanResult
  errorCode        String?
  tenantKey        String     @default("geleoteka")
  createdAt        DateTime   @default(now())

  @@index([tenantKey, createdAt])
  @@index([tenantKey, userId, createdAt])
}

// Stocktake / инвентаризация (Phase 3 of the warehouse roadmap). A count session
// snapshots the in-scope StockBins as count lines, the worker records counted
// quantities (informed: system qty shown), and a manager reviews + posts the
// found/missing/unexpected/unknown variances. Posting is bins-are-truth: per
// part a single ADJUSTMENT (Σ counted−system over counted cells) + each counted
// bin reconciled to its counted qty. Nothing is written until the manager posts.
// WMS-owned, tenant-scoped. itemId is a host partId (no FK, mirrors StockBin).
enum StockCountStatus {
  OPEN // counting in progress
  REVIEW // counting finished, variances awaiting manager post
  POSTED // variances applied to stock
  CANCELLED // abandoned, nothing applied
}

enum StockCountScope {
  ZONE // all locations in a StockLocation.zone
  LOCATION // one or more specific cells
  FULL // every placed location in the tenant
  PART // specific parts wherever they sit
}

enum StockCountClassification {
  FOUND // expected in this cell and counted (qty may still vary)
  MISSING // expected in this cell, not counted (countedQty 0)
  UNEXPECTED // counted in this cell, system had none here
  UNKNOWN // scanned code resolved to no part (posts nothing)
}

model StockCountSession {
  id             String           @id @default(cuid())
  status         StockCountStatus @default(OPEN)
  scope          StockCountScope
  scopeValue     String? // display label (zone name / comma codes / category ref)
  // Resolved scope, persisted so the post-time drift query can enumerate the
  // FULL live scoped bin map (a new bin with no count line still counts as drift).
  // FULL scope = both arrays empty + scope=FULL meaning "all tenant bins".
  scopeLocations String[]
  scopePartIds   String[]
  note           String?
  createdByUserId String?
  postedByUserId String?
  postedAt       DateTime?
  tenantKey      String           @default("geleoteka")
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  lines StockCountLine[]

  @@index([tenantKey, status, createdAt])
}

model StockCountLine {
  id             String                    @id @default(cuid())
  sessionId      String
  itemId         String? // host partId; null for UNKNOWN lines
  rawCode        String? // scanned payload for an UNKNOWN line
  location       String
  systemQty      Int // snapshot of the bin qty at session generation
  countedQty     Int? // null until counted
  classification StockCountClassification?
  postedDelta    Int? // the on-hand delta actually posted for this line
  tenantKey      String                    @default("geleoteka")
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt

  session StockCountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([tenantKey, sessionId])
}

// Parts fulfillment / shipment for a Deal (channel PARTS_*). Renamed from
// PartOrder (the Deal is now the "order"); @@map keeps the DB table "PartOrder"
// so no data moves. The PO-NNNN number + PartOrder_number_seq are unchanged.
model PartShipment {
  id           String          @id @default(cuid())
  // Human-readable PO-NNNN — generated via Postgres sequence in
  // lib/crm/internal/next-number.ts. Nullable for legacy rows; new
  // inserts always carry a value.
  orderNumber  String?         @unique
  userId       String?
  status       PartOrderStatus @default(PROCESSING)
  total        Int             @default(0)
  contactName  String
  contactPhone String
  contactEmail String
  notes        String?
  // One-shot secret returned to a guest immediately after order creation,
  // required by the post-checkout auth panel to claim/login the order.
  // Cleared after the first successful claim or login.
  claimToken   String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  // Deal+Fulfillment: NOT NULL after the backfill (scripts/backfill-fulfillment-deals.ts)
  // guaranteed every row carries a dealId.
  dealId String

  user  User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  deal  Deal            @relation(fields: [dealId], references: [id], onDelete: Cascade)
  items PartOrderItem[]

  @@index([userId])
  @@index([status])
  @@index([claimToken])
  @@index([dealId])
  @@map("PartOrder")
}

model PartOrderItem {
  id        String @id @default(cuid())
  orderId   String
  partId    String
  quantity  Int    @default(1)
  unitPrice Int

  order PartShipment @relation(fields: [orderId], references: [id], onDelete: Cascade)
  part  Part         @relation(fields: [partId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([partId])
}

// ============================================
// RENTAL BOOKINGS
// ============================================

model RentalBooking {
  id             String              @id @default(cuid())
  // Human-readable RB-NNNN — generated via Postgres sequence in
  // lib/crm/internal/next-number.ts. Nullable for legacy rows; new
  // inserts always carry a value.
  bookingNumber  String?             @unique
  vehicleId    String // Was carId — now references Vehicle
  userId       String?
  status       RentalBookingStatus @default(BOOKED)
  startDate    DateTime
  endDate      DateTime
  // Rental cost is NOT denormalized here — it lives on the deal's active
  // estimate (RENTAL_DAY line) and Deal.total. Read it via the deal.
  contactName  String
  contactPhone String
  contactEmail String
  notes        String?
  // One-shot claim secret for guest checkouts. Mirrors RepairOrder.claimToken
  // and PartOrder.claimToken — lets a guest who just booked a rental set a
  // password and merge into the soft-account created at submit time. Cleared
  // (set to NULL) once the guest claims the account.
  claimToken   String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  // Deal+Fulfillment: NOT NULL after the backfill (scripts/backfill-fulfillment-deals.ts)
  // guaranteed every row carries a dealId.
  dealId String

  vehicle Vehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([vehicleId])
  @@index([userId])
  @@index([status])
  @@index([claimToken])
  @@index([dealId])
}

// ============================================
// VACANCIES
// ============================================

model Vacancy {
  id           String   @id @default(cuid())
  title        String
  type         String   @default("Полная занятость")
  description  String
  requirements String[]
  isActive     Boolean  @default(true)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
}

// ============================================
// SUPPLIER ORDERS
// ============================================

model SupplierOrder {
  id               String              @id @default(cuid())
  userId           String // Was supplierId — references User (isSupplier=true)
  orderNumber      String?
  orderDate        DateTime
  status           SupplierOrderStatus @default(DRAFT)
  itemsCost        Int                 @default(0)
  shippingCost     Int                 @default(0)
  customsCost      Int                 @default(0)
  totalCost        Int                 @default(0)
  sellingPrice     Int                 @default(0)
  estimatedProfit  Int                 @default(0)

  // Landed-cost inputs (nullable — old orders have none). Money results stay in
  // the Int-ruble columns above; fractional inputs are scaled ints.
  shippingWeightGrams      Int? // effective weight used (server-computed: override ?? auto-from-catalog)
  manualWeightOverrideGrams Int? // manager override; null = auto from Part.weightGrams
  shippingRateUsdCents     Int? // shipping $/kg ×100
  usdRateKopecks           Int? // USD→RUB rate ×100
  customsMode              CustomsMode @default(PERCENT_CIF)
  customsPercentBps        Int? // customs % in basis points (2600 = 26%)
  cargoRateUsdCents        Int? // cargo $/kg ×100 (CARGO_PER_KG mode)
  trackingNumber   String?
  estimatedArrival DateTime?
  receivedAt       DateTime?
  notes            String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  supplier User                @relation(fields: [userId], references: [id])
  items    SupplierOrderItem[]

  @@index([userId])
  @@index([status])
  @@index([orderDate])
}

model SupplierOrderItem {
  id          String                @id @default(cuid())
  orderId     String
  type             SupplierOrderItemType @default(PART)
  partId           String?
  description      String
  quantity         Int                   @default(1)
  receivedQuantity Int                   @default(0) // cumulative received via scan-receive (Phase 2)
  unitCost         Int
  totalCost        Int

  order SupplierOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  part  Part?         @relation(fields: [partId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([partId])
}

// ============================================
// VEHICLE CATALOG — Manufacturer / Model / Generation
// Source of truth for the picker. Service.applicableModels and
// Part.compatibleModels still use string arrays keyed by VehicleModel.name
// for a soft join — refactoring those to FKs is a follow-up.
// ============================================

model Manufacturer {
  id        String         @id @default(cuid())
  slug      String         @unique
  name      String
  sortOrder Int            @default(0)
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  models    VehicleModel[]

  @@index([isActive, sortOrder])
}

model VehicleModel {
  id             String              @id @default(cuid())
  slug           String              @unique
  name           String
  description    String?
  engines        String?
  features       String[]            @default([])
  manufacturerId String
  sortOrder      Int                 @default(0)
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  manufacturer   Manufacturer        @relation(fields: [manufacturerId], references: [id], onDelete: Cascade)
  generations    VehicleGeneration[]

  @@index([manufacturerId, sortOrder])
  @@index([isActive])
}

model VehicleGeneration {
  id        String        @id @default(cuid())
  code      String
  yearFrom  Int
  yearTo    Int?
  modelId   String
  sortOrder Int           @default(0)
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  model     VehicleModel  @relation(fields: [modelId], references: [id], onDelete: Cascade)
  trims     VehicleTrim[]

  @@unique([modelId, code])
  @@index([modelId, sortOrder])
  @@index([isActive])
}

// Engine/body/drivetrain variant within a generation. One isDefault=true row per
// generation absorbs legacy compatibility data and acts as the "Все варианты"
// fallback for the public picker. Default trims are system-managed — admins
// can't create or delete them; only specific (non-default) trims are
// editable via the TrimManager.
model VehicleTrim {
  id            String    @id @default(cuid())
  generationId  String
  code          String
  bodyStyle     String?
  drivetrain    String?
  fuelType      FuelType?
  engineCode    String?
  displacementL Decimal?  @db.Decimal(3, 1)
  horsepower    Int?
  notes         String?
  isDefault     Boolean   @default(false)
  sortOrder     Int       @default(0)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  generation   VehicleGeneration @relation(fields: [generationId], references: [id], onDelete: Cascade)
  partTrims    PartTrim[]
  repairOrders RepairOrder[]

  @@unique([generationId, code])
  @@index([generationId, sortOrder])
  @@index([isActive])
  @@index([isDefault])
}

// Join table between Part and VehicleTrim. Composite primary key on (partId,
// trimId) prevents duplicates. Cascade from both sides — deleting a part or
// trim drops the link without leaving orphan rows.
model PartTrim {
  partId String
  trimId String

  part Part        @relation(fields: [partId], references: [id], onDelete: Cascade)
  trim VehicleTrim @relation(fields: [trimId], references: [id], onDelete: Cascade)

  @@id([partId, trimId])
  @@index([trimId])
}

// ============================================
// CRM — Deal aggregate + Estimate
// ============================================

/// Deal is the unified commercial aggregate. Workshop service, parts
/// purchases, rentals — everything that involves money commitment is a
/// Deal. Operational fulfillments (RepairOrder, PartOrder, RentalBooking)
/// link back via dealId. Money is denormalized from the active (non-SUPERSEDED)
/// Estimate's EstimateLine[] and is the source of truth for total revenue.
/// See docs/prd/2026-05-10-deal-fulfillment-architecture.md.
model Deal {
  id              String              @id @default(cuid())
  number          String?             @unique
  customerUserId  String
  vehicleId       String? // Optional — parts-only deal may not have one
  ownerUserId     String? // Sales rep / deal owner
  stage           DealStage           @default(NEW)
  channel         DealChannel
  source          String? // "booking-form" | "parts-cart" | "rentals-form" | "walk-in" | "phone"
  paymentStatus   DealPaymentStatus   @default(UNPAID)

  subtotalLabor  Int @default(0)
  subtotalParts  Int @default(0)
  subtotalRental Int @default(0)
  discount       Int @default(0)
  tax            Int @default(0)
  total          Int @default(0)

  quotedAt   DateTime?
  approvedAt DateTime?
  closedAt   DateTime?
  lostReason String?

  // Mirrors RepairOrder/PartOrder/RentalBooking.claimToken for the
  // post-checkout guest auth panel — moves here as the Deal is now the
  // commercial root, and one Deal may have multiple fulfillments.
  claimToken String?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer       User            @relation("DealCustomer", fields: [customerUserId], references: [id], onDelete: Cascade)
  vehicle        Vehicle?        @relation(fields: [vehicleId], references: [id], onDelete: SetNull)
  owner          User?           @relation("DealOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  estimates        Estimate[]
  repairOrders     RepairOrder[]
  partShipments    PartShipment[]
  rentalBookings   RentalBooking[]
  communicationLogs CommunicationLog[]
  tasks            CrmTask[]

  @@index([customerUserId])
  @@index([vehicleId])
  @@index([ownerUserId])
  @@index([stage])
  @@index([channel])
  @@index([claimToken])
  @@index([createdAt])
}

// DealLine model removed (refactor 2026-05-18). The active non-SUPERSEDED
// Estimate's EstimateLine[] is now the single source of truth for "what is
// being sold" on a deal. Deal.subtotal*/total stay denormalized for list
// pages; recompute reads from the active estimate.

/// Estimate is a frozen sales document attached to a Deal. A Deal may have
/// 0..N estimates (revisions chain via parentEstimateId). Money on an
/// Estimate is captured at SENT time and is the historical contract; the
/// Deal continues evolving independently.
model Estimate {
  id               String        @id @default(cuid())
  number           String?       @unique
  dealId           String
  stage            EstimateStage @default(DRAFT)
  preparedByUserId String?
  validUntil       DateTime?
  parentEstimateId String?
  notes            String?
  sentAt           DateTime?
  approvedAt       DateTime?
  declinedAt       DateTime?
  declineReason    String?

  subtotalLabor  Int @default(0)
  subtotalParts  Int @default(0)
  subtotalRental Int @default(0)
  discount       Int @default(0)
  tax            Int @default(0)
  taxRate        Int @default(20) // percent of (subtotal − discount); new estimates default 20%, pre-existing backfilled to 0
  total          Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deal          Deal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  preparedBy    User?          @relation("EstimatePreparedBy", fields: [preparedByUserId], references: [id], onDelete: SetNull)
  parent        Estimate?      @relation("EstimateRevision", fields: [parentEstimateId], references: [id], onDelete: SetNull)
  revisions     Estimate[]     @relation("EstimateRevision")
  estimateLines EstimateLine[]

  @@index([dealId])
  @@index([stage])
  @@index([number])
  // Compound — covers the hot openOrCreateActiveEstimate path
  // (findFirst dealId + stage="DRAFT" and dealId + stage != "SUPERSEDED")
  // without forcing Postgres to pick a single-column index and post-filter.
  @@index([dealId, stage])
}

model EstimateLine {
  id          String       @id @default(cuid())
  estimateId  String
  sortOrder   Int          @default(0)
  type        DealLineType
  description String
  qty         Float        @default(1)
  unitPrice   Int          @default(0)
  total       Int          @default(0)
  partId      String?

  createdAt DateTime @default(now())

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)
  part     Part?    @relation(fields: [partId], references: [id], onDelete: SetNull)

  @@index([estimateId, sortOrder])
  @@index([partId])
}

// ============================================
// CRM — Communications & Tasks
// ============================================

/// Communication touch with a customer. The manager logs phone calls /
/// in-person visits manually; system events (smsc.ru delivery reports,
/// future WhatsApp/Telegram webhooks) write here automatically. Always
/// attached to a customer; optionally pinned to a specific Deal so
/// per-deal timelines stay coherent.
model CommunicationLog {
  id             String      @id @default(cuid())
  customerUserId String
  authorUserId   String? // Manager who logged it; null = system / inbound webhook
  dealId         String? // Optional deal context
  channel        CommChannel
  outcome        CommOutcome @default(N_A)
  body           String? // Message text or call summary
  durationSec    Int? // For calls
  // Provider message id (smsc.ru, Resend Message-Id header for email). @unique
  // makes the inbound webhook idempotent against duplicate delivery. Nullable
  // — most non-email rows leave it null; PG treats multiple NULLs as distinct.
  externalId     String?     @unique
  // Email-only fields. Populated for EMAIL_INBOUND/EMAIL_OUTBOUND, null otherwise.
  subject        String?
  resendEmailId  String? // Resend's UUID — required for the attachment proxy
  attachments    Json        @default("[]") // [{ id, filename, content_type, content_disposition, content_id? }]
  createdAt      DateTime    @default(now())
  // Per-message read state for in-page timeline styling on Customer 360 / Deal
  // pages. Set non-null by `markRepliesRead` server action when a manager opens
  // the page. NOT used by the unread-replies badge — that counts OPEN FOLLOW_UP
  // tasks instead, so any manager opening a page doesn't clear another
  // manager's per-user action queue.
  readAt         DateTime?

  customer            User           @relation("CommLogCustomer", fields: [customerUserId], references: [id], onDelete: Cascade)
  author              User?          @relation("CommLogAuthor", fields: [authorUserId], references: [id], onDelete: SetNull)
  deal                Deal?          @relation(fields: [dealId], references: [id], onDelete: SetNull)
  linkedInboxMessages InboxMessage[] @relation("InboxLinkedCommLog")

  @@index([customerUserId, createdAt])
  @@index([dealId])
  @@index([channel])
  @@index([resendEmailId])
  @@index([customerUserId, channel, readAt])
}

/// Bucket for inbound emails from unknown senders (no User.email match, no
/// In-Reply-To match). Managers triage from /admin/crm/inbox: link to a
/// customer, create a new customer, mark spam, or archive. Linking copies
/// the row into CommunicationLog (channel EMAIL_INBOUND) and flips status
/// to ASSIGNED — the InboxMessage row itself is never deleted (audit).
model InboxMessage {
  id                       String             @id @default(cuid())
  fromEmail                String
  fromName                 String?
  toEmail                  String
  subject                  String
  bodyText                 String?
  bodyHtml                 String?
  attachments              Json               @default("[]")
  messageId                String             @unique
  inReplyTo                String?
  references               String[]           @default([])
  resendEmailId            String             @unique
  receivedAt               DateTime           @default(now())
  status                   InboxMessageStatus @default(PENDING)
  assignedToUserId         String?
  linkedCommunicationLogId String?

  assignedTo             User?             @relation("InboxAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  linkedCommunicationLog CommunicationLog? @relation("InboxLinkedCommLog", fields: [linkedCommunicationLogId], references: [id], onDelete: SetNull)

  @@index([status, receivedAt])
  @@index([inReplyTo])
  @@index([fromEmail])
}

/// CRM task — a reminder/follow-up assigned to a manager. May be linked
/// to a customer and/or a specific deal so the Customer 360 and Deal
/// detail pages can show outstanding work.
model CrmTask {
  id             String        @id @default(cuid())
  title          String
  body           String?
  kind           CrmTaskKind   @default(GENERIC)
  status         CrmTaskStatus @default(OPEN)
  dueAt          DateTime
  ownerUserId    String
  customerUserId String?
  dealId         String?
  completedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  owner    User  @relation("CrmTaskOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  customer User? @relation("CrmTaskCustomer", fields: [customerUserId], references: [id], onDelete: SetNull)
  deal     Deal? @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([ownerUserId, status, dueAt])
  @@index([customerUserId])
  @@index([dealId])
  @@index([dueAt])
}
